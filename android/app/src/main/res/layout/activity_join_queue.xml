<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/toolbar_dark"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Select Service"
            app:titleTextColor="@color/white" />

        <!-- Header Section -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="What do you need help with?"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Choose a bursary service to join the queue."
                android:textColor="@color/gray_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Service Cards Container -->
        <LinearLayout
            android:id="@+id/servicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/headerSection">

            <!-- Student Account Service -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudentAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Icon Background -->
                    <View
                        android:id="@+id/iconBgStudentAccount"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="#1E3A8A"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Icon -->
                    <ImageView
                        android:id="@+id/iconStudentAccount"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_school"
                        app:layout_constraintBottom_toBottomOf="@id/iconBgStudentAccount"
                        app:layout_constraintEnd_toEndOf="@id/iconBgStudentAccount"
                        app:layout_constraintStart_toStartOf="@id/iconBgStudentAccount"
                        app:layout_constraintTop_toTopOf="@id/iconBgStudentAccount"
                        app:tint="@color/primary_blue" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvStudentAccountTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Student Account"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/tvStudentAccountWaiting"
                        app:layout_constraintStart_toEndOf="@id/iconBgStudentAccount"
                        app:layout_constraintTop_toTopOf="@id/iconBgStudentAccount" />

                    <!-- Waiting Count -->
                    <TextView
                        android:id="@+id/tvStudentAccountWaiting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="4dp"
                        android:text="14 Waiting"
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_people"
                        app:drawableTint="@color/primary_blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgStudentAccount" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tvStudentAccountDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Inquiries regarding tuition fees, outstanding balances, and account statements."
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgStudentAccount"
                        app:layout_constraintTop_toBottomOf="@id/tvStudentAccountTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Collection Service -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCollection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Icon Background -->
                    <View
                        android:id="@+id/iconBgCollection"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="#064E3B"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Icon -->
                    <ImageView
                        android:id="@+id/iconCollection"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_payment"
                        app:layout_constraintBottom_toBottomOf="@id/iconBgCollection"
                        app:layout_constraintEnd_toEndOf="@id/iconBgCollection"
                        app:layout_constraintStart_toStartOf="@id/iconBgCollection"
                        app:layout_constraintTop_toTopOf="@id/iconBgCollection"
                        app:tint="#10B981" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvCollectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Collection"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/tvCollectionWaiting"
                        app:layout_constraintStart_toEndOf="@id/iconBgCollection"
                        app:layout_constraintTop_toTopOf="@id/iconBgCollection" />

                    <!-- Waiting Count -->
                    <TextView
                        android:id="@+id/tvCollectionWaiting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="4dp"
                        android:text="3 Waiting"
                        android:textColor="#10B981"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_people"
                        app:drawableTint="#10B981"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgCollection" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tvCollectionDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Collect refund checks, allowance payouts, or physical financial documents."
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgCollection"
                        app:layout_constraintTop_toBottomOf="@id/tvCollectionTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Scholarship Inquiry Service -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardScholarship"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Icon Background -->
                    <View
                        android:id="@+id/iconBgScholarship"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="#7C2D12"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Icon -->
                    <ImageView
                        android:id="@+id/iconScholarship"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_award"
                        app:layout_constraintBottom_toBottomOf="@id/iconBgScholarship"
                        app:layout_constraintEnd_toEndOf="@id/iconBgScholarship"
                        app:layout_constraintStart_toStartOf="@id/iconBgScholarship"
                        app:layout_constraintTop_toTopOf="@id/iconBgScholarship"
                        app:tint="#F97316" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvScholarshipTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Scholarship Inquiry"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/tvScholarshipWaiting"
                        app:layout_constraintStart_toEndOf="@id/iconBgScholarship"
                        app:layout_constraintTop_toTopOf="@id/iconBgScholarship" />

                    <!-- Waiting Count -->
                    <TextView
                        android:id="@+id/tvScholarshipWaiting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="4dp"
                        android:text="6 Waiting"
                        android:textColor="#F97316"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:drawableStartCompat="@drawable/ic_people"
                        app:drawableTint="#F97316"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/iconBgScholarship" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tvScholarshipDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Information on bursaries, merit scholarships, and external funding applications."
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconBgScholarship"
                        app:layout_constraintTop_toBottomOf="@id/tvScholarshipTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- FAQ Notice -->
        <LinearLayout
            android:id="@+id/faqNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/servicesContainer">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_info"
                app:tint="@color/primary_blue" />

            <TextView
                android:id="@+id/tvFaqNotice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:textColor="@color/gray_text"
                android:textSize="13sp">
            </TextView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>